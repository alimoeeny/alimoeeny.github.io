---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div id="game-container" style="width: 100%; height: 80vh; border: 1px solid #ccc;"></div>
 <script>
  console.log('Astro page script tag executing...');

  import { initGame } from '../lib/inside-game.ts';

  console.log('initGame imported:', initGame);

  document.addEventListener('DOMContentLoaded', () => {
    console.log('DOMContentLoaded event fired.');
    const gameContainer = document.getElementById('game-container');
    if (gameContainer) {
      console.log('Game container found. Calling initGame...');
      initGame('game-container');
    } else {
      console.error('Failed to find the game container element on the page.');
    }
  });
</script>
</Layout>

<style>
  #game-container {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
  }
  /* Additional styling for the game canvas can be added here or in a separate CSS file */
</style>

